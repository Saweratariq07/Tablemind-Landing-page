VITE_WEB3FORMS_WAITLIST_KEY=your_hello_form_access_key
# Demo form → demo@tablemind.co
VITE_WEB3FORMS_DEMO_KEY=your_demo_form_access_key

# Vercel: Project → Settings → Environment Variables
# Add both keys above for Production + Preview, then redeploy.
